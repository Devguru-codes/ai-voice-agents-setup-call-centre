# ── PostgreSQL Database ───────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/voiceagent

# ── Redis (Session state & memory) ────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Groq API (Primary LLM) ──────────────────────────────────────────────────────
# Supports comma-separated keys for rate limit rotation.
GROQ_API_KEY=gsk_your_groq_key_here

# ── Ollama (Fallback LLM) ─────────────────────────────────────────────────────
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.1

# ── Faster Whisper (Local STT) ────────────────────────────────────────────────
WHISPER_MODEL=base.en
WHISPER_DEVICE=auto

# ── Edge TTS (Free TTS) ───────────────────────────────────────────────────────
EDGE_TTS_VOICE=en-US-JennyNeural

# ── LiveKit (Optional: if routing via external LiveKit server instead of local)
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret
LIVEKIT_URL=ws://localhost:7880

# ── Environment ───────────────────────────────────────────────────────────────
# Set to 'false' in production
DEBUG=true

# ── RAG configuration ─────────────────────────────────────────────────────────
# Model used for generating embeddings via sentence-transformers (local CPU)
EMBEDDING_MODEL=all-MiniLM-L6-v2
